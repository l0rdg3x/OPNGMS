{
  "index_patterns": ["opngms-logs-*"],
  "template": {
    "settings": {
      "number_of_shards": 2,
      "number_of_replicas": 1,
      "plugins.index_state_management.policy_id": "opngms-logs-retention"
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "tenant_id": { "type": "keyword" },
        "device_id": { "type": "keyword" },
        "host": { "type": "keyword" },
        "program": { "type": "keyword" },
        "message": { "type": "text" }
      }
    }
  }
}
