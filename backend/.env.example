# App runtime: the NON-superuser role (RLS actually constrains it)
DATABASE_URL=postgresql+asyncpg://opngms_app:opngms_app@localhost:5432/opngms
# Migrations / worker: the owner (can create roles and tables, bypasses RLS)
ADMIN_DATABASE_URL=postgresql+asyncpg://opngms:opngms@localhost:5432/opngms
TEST_DATABASE_URL=postgresql+asyncpg://opngms:opngms@localhost:5432/opngms_test
SESSION_SECRET=change-me-session-secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=change-me-fernet-key
# Comma-separated retired Fernet keys kept for decryption only during rotation; empty when not rotating.
MASTER_KEY_OLD_KEYS=
SESSION_TTL_HOURS=12
SESSION_IDLE_MINUTES=120
REDIS_URL=redis://localhost:6379
POLL_INTERVAL_SECONDS=60
# Worker cron cadences (optional; sane defaults shown)
INGEST_EVERY_MINUTES=5
CONFIG_BACKUP_HOUR=3
REPORT_WEEKDAY=mon
REPORT_HOUR=4
