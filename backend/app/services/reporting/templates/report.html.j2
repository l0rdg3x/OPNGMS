<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <style>{{ css }}</style>
</head>
<body>
  <div class="tz-meta" data-tz="{{ ctx.timezone }}" data-owner="{{ ctx.owner or '—' }}" data-ftz="{{ ctx.t.footer_tz }}" data-fowner="{{ ctx.t.footer_owner }}" data-fpage="{{ ctx.t.footer_page }}" data-fof="{{ ctx.t.footer_of }}"></div>

  <section class="title-page">
    {% if ctx.logo_data_uri %}<img class="logo" src="{{ ctx.logo_data_uri }}" alt="logo" />{% endif %}
    <h1>{{ ctx.title }}</h1>
    <div class="tenant">{{ ctx.tenant_name }}</div>
    <div class="range">{{ ctx.range_from.strftime('%Y-%m-%d') }} – {{ ctx.range_to.strftime('%Y-%m-%d') }}</div>
  </section>

  <section class="toc">
    <h2>{{ ctx.t.toc_title }}</h2>
    <ol>
      {% for name in ctx.toc %}<li>{{ name }}</li>{% endfor %}
    </ol>
  </section>

  {% for section in ctx.sections %}
  <section class="device-section">
    <h2>{{ section.device_name }}</h2>

    {% if section.attacks %}
    <h3>{{ ctx.t.attacks_title }}</h3>
    <p class="explain">{{ ctx.t.attacks_explain }}</p>
    <div class="chart">{{ Markup(section.attacks.timeline_svg) }}</div>
    {% for tbl in section.attacks.tables %}
    <table class="ranked">
      <caption>{{ tbl.title }}</caption>
      <thead><tr><th>{{ tbl.columns[0] }}</th><th>{{ tbl.columns[1] }}</th></tr></thead>
      <tbody>
        {% for value, count in tbl.rows %}<tr><td>{{ value }}</td><td>{{ count }}</td></tr>{% endfor %}
        {% if not tbl.rows %}<tr><td colspan="2">{{ ctx.t.no_data }}</td></tr>{% endif %}
      </tbody>
    </table>
    {% endfor %}
    {% endif %}

    {% if section.web %}
    <h3>{{ ctx.t.web_title }}</h3>
    <p class="explain">{{ ctx.t.web_explain }}</p>
    <div class="chart">{{ Markup(section.web.timeline_svg) }}</div>
    {% for tbl in [section.web.top_sites, section.web.top_initiators, section.web.top_blocked] %}
    <table class="ranked">
      <caption>{{ tbl.title }}</caption>
      <thead><tr><th>{{ tbl.columns[0] }}</th><th>{{ tbl.columns[1] }}</th></tr></thead>
      <tbody>
        {% for value, count in tbl.rows %}<tr><td>{{ value }}</td><td>{{ count }}</td></tr>{% endfor %}
        {% if not tbl.rows %}<tr><td colspan="2">{{ ctx.t.no_data }}</td></tr>{% endif %}
      </tbody>
    </table>
    {% endfor %}
    {% endif %}

    {% if section.bandwidth %}
    <h3>{{ ctx.t.data_title }}</h3>
    <p class="explain">{{ ctx.t.data_explain }}</p>
    <div class="chart">{{ Markup(section.bandwidth.timeline_svg) }}</div>
    <p class="summary">{{ ctx.t.total_in }}: {{ section.bandwidth.total_in }} · {{ ctx.t.total_out }}: {{ section.bandwidth.total_out }}</p>
    {% endif %}

    {% if section.status %}
    <h3>{{ ctx.t.status_title }}</h3>
    <p class="explain">{{ ctx.t.status_explain }}</p>
    <div class="chart">{{ Markup(section.status.timeline_svg) }}</div>
    <p class="summary">{{ ctx.t.uptime }}: {{ section.status.uptime_pct }}%</p>
    {% endif %}

    {% if section.applications %}
    <h3>{{ ctx.t.apps_title }}</h3>
    <p class="sample-note">{{ ctx.t.apps_sample }}</p>
    <p class="explain">{{ ctx.t.apps_explain }}</p>
    <div class="chart">{{ Markup(section.applications.timeline_svg) }}</div>
    {% for tbl in [section.applications.top_detected, section.applications.top_blocked, section.applications.top_categories] %}
    <table class="ranked">
      <caption>{{ tbl.title }}</caption>
      <thead><tr><th>{{ tbl.columns[0] }}</th><th>{{ tbl.columns[1] }}</th><th>{{ ctx.t.threat }}</th></tr></thead>
      <tbody>
        {% for row in tbl.rows %}
        <tr><td>{{ row.label }}</td><td>{{ row.count }}</td>
            <td><span class="threat threat-{{ row.level }}">{{ ctx.t['threat_' ~ row.level] }}</span></td></tr>
        {% endfor %}
      </tbody>
    </table>
    {% endfor %}
    <table class="ranked">
      <caption>{{ section.applications.top_initiators.title }}</caption>
      <thead><tr><th>{{ section.applications.top_initiators.columns[0] }}</th><th>{{ section.applications.top_initiators.columns[1] }}</th></tr></thead>
      <tbody>
        {% for value, count in section.applications.top_initiators.rows %}<tr><td>{{ value }}</td><td>{{ count }}</td></tr>{% endfor %}
      </tbody>
    </table>
    {% endif %}

    {% if section.web_filter %}
    <h3>{{ ctx.t.webfilter_title }}</h3>
    <p class="sample-note">{{ ctx.t.webfilter_sample }}</p>
    <p class="explain">{{ ctx.t.webfilter_explain }}</p>
    <div class="chart">{{ Markup(section.web_filter.timeline_svg) }}</div>
    <table class="ranked">
      <caption>{{ section.web_filter.top_categories.title }}</caption>
      <thead><tr><th>{{ section.web_filter.top_categories.columns[0] }}</th><th>{{ section.web_filter.top_categories.columns[1] }}</th><th>{{ ctx.t.threat }}</th></tr></thead>
      <tbody>
        {% for row in section.web_filter.top_categories.rows %}
        <tr><td>{{ row.label }}</td><td>{{ row.count }}</td>
            <td><span class="threat threat-{{ row.level }}">{{ ctx.t['threat_' ~ row.level] }}</span></td></tr>
        {% endfor %}
      </tbody>
    </table>
    {% for tbl in [section.web_filter.top_sites, section.web_filter.top_initiators] %}
    <table class="ranked">
      <caption>{{ tbl.title }}</caption>
      <thead><tr><th>{{ tbl.columns[0] }}</th><th>{{ tbl.columns[1] }}</th></tr></thead>
      <tbody>
        {% for value, count in tbl.rows %}<tr><td>{{ value }}</td><td>{{ count }}</td></tr>{% endfor %}
      </tbody>
    </table>
    {% endfor %}
    {% endif %}

  </section>
  {% endfor %}
</body>
</html>
