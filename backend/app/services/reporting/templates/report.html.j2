<!DOCTYPE html>
<html lang="{{ ctx.locale }}" dir="{{ ctx.dir }}">
<head>
  <meta charset="utf-8" />
  <style>{{ css }}</style>
</head>
<body>
  <div class="tz-meta" data-tz="{{ ctx.timezone }}" data-owner="{{ ctx.owner or '—' }}" data-ftz="{{ ctx.t.footer_tz }}" data-fowner="{{ ctx.t.footer_owner }}" data-fpage="{{ ctx.t.footer_page }}" data-fof="{{ ctx.t.footer_of }}"></div>

  <section class="title-page">
    {% if ctx.logo_data_uri %}<img class="logo" src="{{ ctx.logo_data_uri }}" alt="logo" />{% endif %}
    <h1>{{ ctx.title }}</h1>
    <div class="tenant">{{ ctx.tenant_name }}</div>
    <div class="range">{{ ctx.range_from.strftime('%Y-%m-%d') }} – {{ ctx.range_to.strftime('%Y-%m-%d') }}</div>
  </section>

  <section class="toc">
    <h2>{{ ctx.t.toc_title }}</h2>
    <ol>
      {% for name in ctx.toc %}<li>{{ name }}</li>{% endfor %}
    </ol>
  </section>

  {% if ctx.summary %}
  <section class="summary-band">
    <h2>{{ ctx.t.summary_title }}</h2>
    <p class="explain">{{ ctx.t.summary_explain }}</p>
    <div class="kpis">
      <div class="kpi"><div class="kpi-value">{{ ctx.summary.devices_total }}</div><div class="kpi-label">{{ ctx.t.kpi_devices }}</div></div>
      <div class="kpi"><div class="kpi-value">{{ ctx.summary.devices_online }}</div><div class="kpi-label">{{ ctx.t.kpi_online }}</div></div>
      <div class="kpi"><div class="kpi-value">{{ ctx.summary.attacks_blocked }}</div><div class="kpi-label">{{ ctx.t.kpi_attacks }}</div></div>
      <div class="kpi"><div class="kpi-value">{{ ctx.summary.data_total }}</div><div class="kpi-label">{{ ctx.t.kpi_data }}</div></div>
      <div class="kpi"><div class="kpi-value">{{ ctx.summary.uptime_pct }}%</div><div class="kpi-label">{{ ctx.t.kpi_uptime }}</div></div>
      <div class="kpi"><div class="kpi-value">{{ ctx.summary.alerts_count }}</div><div class="kpi-label">{{ ctx.t.kpi_alerts }}</div></div>
    </div>
  </section>
  {% endif %}

  {% if ctx.attacker_countries %}
  <section class="attacker-countries">
    <h2>{{ ctx.t.attacker_countries_title }}</h2>
    <p class="explain">{{ ctx.t.attacker_countries_explain }}</p>
    {% if ctx.attacker_countries.map_svg %}<div class="chart">{{ Markup(ctx.attacker_countries.map_svg) }}</div>{% endif %}
    <table class="ranked">
      <thead><tr><th>{{ ctx.t.col_country }}</th><th>{{ ctx.t.col_count }}</th><th>{{ ctx.t.col_share }}</th></tr></thead>
      <tbody>
        {% for row in ctx.attacker_countries.rows %}<tr><td>{{ row.name }}</td><td>{{ row.count }}</td><td>{{ row.pct }}%</td></tr>{% endfor %}
        {% if not ctx.attacker_countries.rows %}<tr><td colspan="3">{{ ctx.t.no_data }}</td></tr>{% endif %}
      </tbody>
    </table>
    <p class="attribution">{{ ctx.t.geoip_attribution }}</p>
  </section>
  {% endif %}

  {% if ctx.failed_logins %}
  <section class="perimeter failed-logins">
    <h2>{{ ctx.t.failed_logins_title }}</h2>
    <table class="ranked">
      <thead><tr><th>{{ ctx.t.col_src_ip }}</th><th>{{ ctx.t.col_country }}</th><th>{{ ctx.t.col_user }}</th><th>{{ ctx.t.col_count }}</th></tr></thead>
      <tbody>
        {% for row in ctx.failed_logins.rows %}<tr><td>{{ row.src_ip }}</td><td>{{ row.country }}</td><td>{{ row.label }}</td><td>{{ row.count }}</td></tr>{% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  {% if ctx.firewall_blocks %}
  <section class="perimeter firewall-blocks">
    <h2>{{ ctx.t.firewall_blocks_title }}</h2>
    <table class="ranked">
      <thead><tr><th>{{ ctx.t.col_src_ip }}</th><th>{{ ctx.t.col_country }}</th><th>{{ ctx.t.col_port }}</th><th>{{ ctx.t.col_count }}</th></tr></thead>
      <tbody>
        {% for row in ctx.firewall_blocks.rows %}<tr><td>{{ row.src_ip }}</td><td>{{ row.country }}</td><td>{{ row.label }}</td><td>{{ row.count }}</td></tr>{% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  {% if ctx.reliability %}
  <section class="reliability">
    <h2>{{ ctx.t.reliability_title }}</h2>
    <p class="explain">{{ ctx.t.reliability_explain }}</p>
    <table class="ranked">
      <caption>{{ ctx.t.reliability_by_category }}</caption>
      <thead><tr><th>{{ ctx.t.col_category }}</th><th>{{ ctx.t.col_count }}</th><th>{{ ctx.t.col_share }}</th></tr></thead>
      <tbody>
        {% for row in ctx.reliability.categories %}<tr><td>{{ row.label }}</td><td>{{ row.count }}</td><td>{{ row.pct }}%</td></tr>{% endfor %}
        {% if not ctx.reliability.categories %}<tr><td colspan="3">{{ ctx.t.no_data }}</td></tr>{% endif %}
      </tbody>
    </table>
    <table class="ranked">
      <caption>{{ ctx.t.reliability_notable }}</caption>
      <thead><tr><th>{{ ctx.t.col_when }}</th><th>{{ ctx.t.col_category }}</th><th>{{ ctx.t.col_event }}</th><th>{{ ctx.t.col_severity }}</th><th>{{ ctx.t.col_device }}</th></tr></thead>
      <tbody>
        {% for row in ctx.reliability.events %}<tr><td>{{ row.time }}</td><td>{{ row.category }}</td><td>{{ row.name }}</td><td><span class="sev sev-{{ row.severity }}">{{ row.severity_label }}</span></td><td>{{ row.device }}</td></tr>{% endfor %}
        {% if not ctx.reliability.events %}<tr><td colspan="5">{{ ctx.t.no_data }}</td></tr>{% endif %}
      </tbody>
    </table>
  </section>
  {% endif %}

  {% for section in ctx.sections %}
  <section class="device-section">
    <h2>{{ section.device_name }}</h2>

    {% if section.health %}
    <h3>{{ ctx.t.health_title }}</h3>
    <p class="explain">{{ ctx.t.health_explain }}</p>
    {% if section.health.has_data %}
    <table class="ranked health-table">
      <thead><tr><th></th><th>{{ ctx.t.health_avg }}</th><th>{{ ctx.t.health_peak }}</th></tr></thead>
      <tbody>
        <tr><td>{{ ctx.t.health_cpu }}</td><td>{{ '%.1f'|format(section.health.cpu_avg) if section.health.cpu_avg is not none else ctx.t.no_data }}%</td><td>{{ '%.1f'|format(section.health.cpu_peak) if section.health.cpu_peak is not none else ctx.t.no_data }}%</td></tr>
        <tr><td>{{ ctx.t.health_mem }}</td><td>{{ '%.1f'|format(section.health.mem_avg) if section.health.mem_avg is not none else ctx.t.no_data }}%</td><td>{{ '%.1f'|format(section.health.mem_peak) if section.health.mem_peak is not none else ctx.t.no_data }}%</td></tr>
        <tr><td>{{ ctx.t.health_disk }}</td><td>{{ '%.1f'|format(section.health.disk_avg) if section.health.disk_avg is not none else ctx.t.no_data }}%</td><td>{{ '%.1f'|format(section.health.disk_peak) if section.health.disk_peak is not none else ctx.t.no_data }}%</td></tr>
      </tbody>
    </table>
    <div class="chart">{{ Markup(section.health.sparkline_svg) }}</div>
    {% else %}
    <p class="summary">{{ ctx.t.health_no_data }}</p>
    {% endif %}
    {% endif %}

    {% if section.alerts_wan %}
    <h3>{{ ctx.t.alerts_wan_title }}</h3>
    <p class="explain">{{ ctx.t.alerts_wan_explain }}</p>
    <table class="ranked">
      <caption>{{ ctx.t.alerts_subtitle }}</caption>
      <thead><tr><th>{{ ctx.t.col_alert }}</th><th>{{ ctx.t.col_severity }}</th><th>{{ ctx.t.col_opened }}</th><th>{{ ctx.t.col_duration }}</th></tr></thead>
      <tbody>
        {% for a in section.alerts_wan.alerts %}
        <tr><td>{{ a.title }}</td><td><span class="sev sev-{{ a.severity }}">{{ a.severity_label }}</span></td><td>{{ a.opened }}</td><td>{{ a.duration }}</td></tr>
        {% endfor %}
        {% if not section.alerts_wan.alerts %}<tr><td colspan="4">{{ ctx.t.no_alerts }}</td></tr>{% endif %}
      </tbody>
    </table>
    {% if section.alerts_wan.gateways %}
    <table class="ranked">
      <caption>{{ ctx.t.wan_subtitle }}</caption>
      <thead><tr><th>{{ ctx.t.col_gateway }}</th><th>{{ ctx.t.col_rtt }}</th><th>{{ ctx.t.col_loss }}</th><th>{{ ctx.t.col_availability }}</th></tr></thead>
      <tbody>
        {% for g in section.alerts_wan.gateways %}
        <tr><td>{{ g.name }}</td><td>{{ '%.1f'|format(g.rtt_ms) if g.rtt_ms is not none else ctx.t.no_data }}</td><td>{{ '%.1f'|format(g.loss_pct) if g.loss_pct is not none else ctx.t.no_data }}</td><td>{{ g.up_pct }}%</td></tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% if section.alerts_wan.vpns %}
    <table class="ranked">
      <caption>{{ ctx.t.vpn_subtitle }}</caption>
      <thead><tr><th>{{ ctx.t.col_tunnel }}</th><th>{{ ctx.t.uptime }}</th></tr></thead>
      <tbody>
        {% for v in section.alerts_wan.vpns %}<tr><td>{{ v.name }}</td><td>{{ v.up_pct }}%</td></tr>{% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% endif %}

    {% if section.attacks %}
    <h3>{{ ctx.t.attacks_title }}</h3>
    <p class="explain">{{ ctx.t.attacks_explain }}</p>
    <div class="chart">{{ Markup(section.attacks.timeline_svg) }}</div>
    {% for tbl in section.attacks.tables %}
    <table class="ranked">
      <caption>{{ tbl.title }}</caption>
      <thead><tr><th>{{ tbl.columns[0] }}</th><th>{{ tbl.columns[1] }}</th></tr></thead>
      <tbody>
        {% for value, count in tbl.rows %}<tr><td>{{ value }}</td><td>{{ count }}</td></tr>{% endfor %}
        {% if not tbl.rows %}<tr><td colspan="2">{{ ctx.t.no_data }}</td></tr>{% endif %}
      </tbody>
    </table>
    {% endfor %}
    {% endif %}

    {% if section.web %}
    <h3>{{ ctx.t.web_title }}</h3>
    <p class="explain">{{ ctx.t.web_explain }}</p>
    <div class="chart">{{ Markup(section.web.timeline_svg) }}</div>
    {% for tbl in [section.web.top_sites, section.web.top_initiators, section.web.top_blocked] %}
    <table class="ranked">
      <caption>{{ tbl.title }}</caption>
      <thead><tr><th>{{ tbl.columns[0] }}</th><th>{{ tbl.columns[1] }}</th></tr></thead>
      <tbody>
        {% for value, count in tbl.rows %}<tr><td>{{ value }}</td><td>{{ count }}</td></tr>{% endfor %}
        {% if not tbl.rows %}<tr><td colspan="2">{{ ctx.t.no_data }}</td></tr>{% endif %}
      </tbody>
    </table>
    {% endfor %}
    {% endif %}

    {% if section.bandwidth %}
    <h3>{{ ctx.t.data_title }}</h3>
    <p class="explain">{{ ctx.t.data_explain }}</p>
    <div class="chart">{{ Markup(section.bandwidth.timeline_svg) }}</div>
    <p class="summary">{{ ctx.t.total_in }}: {{ section.bandwidth.total_in }} · {{ ctx.t.total_out }}: {{ section.bandwidth.total_out }}</p>
    {% endif %}

    {% if section.status %}
    <h3>{{ ctx.t.status_title }}</h3>
    <p class="explain">{{ ctx.t.status_explain }}</p>
    <div class="chart">{{ Markup(section.status.timeline_svg) }}</div>
    <p class="summary">{{ ctx.t.uptime }}: {{ section.status.uptime_pct }}%</p>
    {% endif %}

    {% if section.firmware_config %}
    <h3>{{ ctx.t.firmware_config_title }}</h3>
    <p class="explain">{{ ctx.t.firmware_config_explain }}</p>
    <p class="summary">{{ ctx.t.fw_version }}: {{ section.firmware_config.firmware_version }} · {{ ctx.t.fw_edition }}: {{ section.firmware_config.edition }} · {{ ctx.t.fw_series }}: {{ section.firmware_config.series }}</p>
    <table class="ranked">
      <caption>{{ ctx.t.fw_changes }} ({{ section.firmware_config.change_count }})</caption>
      <thead><tr><th>{{ ctx.t.col_change }}</th><th>{{ ctx.t.col_applied }}</th></tr></thead>
      <tbody>
        {% for c in section.firmware_config.changes %}<tr><td>{{ c.summary }}</td><td>{{ c.applied }}</td></tr>{% endfor %}
        {% if not section.firmware_config.changes %}<tr><td colspan="2">{{ ctx.t.no_changes }}</td></tr>{% endif %}
      </tbody>
    </table>
    {% endif %}

    {% if section.applications %}
    <h3>{{ ctx.t.apps_title }}</h3>
    <p class="sample-note">{{ ctx.t.apps_sample }}</p>
    <p class="explain">{{ ctx.t.apps_explain }}</p>
    <div class="chart">{{ Markup(section.applications.timeline_svg) }}</div>
    {% for tbl in [section.applications.top_detected, section.applications.top_blocked, section.applications.top_categories] %}
    <table class="ranked">
      <caption>{{ tbl.title }}</caption>
      <thead><tr><th>{{ tbl.columns[0] }}</th><th>{{ tbl.columns[1] }}</th><th>{{ ctx.t.threat }}</th></tr></thead>
      <tbody>
        {% for row in tbl.rows %}
        <tr><td>{{ row.label }}</td><td>{{ row.count }}</td>
            <td><span class="threat threat-{{ row.level }}">{{ ctx.t['threat_' ~ row.level] }}</span></td></tr>
        {% endfor %}
      </tbody>
    </table>
    {% endfor %}
    <table class="ranked">
      <caption>{{ section.applications.top_initiators.title }}</caption>
      <thead><tr><th>{{ section.applications.top_initiators.columns[0] }}</th><th>{{ section.applications.top_initiators.columns[1] }}</th></tr></thead>
      <tbody>
        {% for value, count in section.applications.top_initiators.rows %}<tr><td>{{ value }}</td><td>{{ count }}</td></tr>{% endfor %}
      </tbody>
    </table>
    {% endif %}

    {% if section.web_filter %}
    <h3>{{ ctx.t.webfilter_title }}</h3>
    <p class="sample-note">{{ ctx.t.webfilter_sample }}</p>
    <p class="explain">{{ ctx.t.webfilter_explain }}</p>
    <div class="chart">{{ Markup(section.web_filter.timeline_svg) }}</div>
    <table class="ranked">
      <caption>{{ section.web_filter.top_categories.title }}</caption>
      <thead><tr><th>{{ section.web_filter.top_categories.columns[0] }}</th><th>{{ section.web_filter.top_categories.columns[1] }}</th><th>{{ ctx.t.threat }}</th></tr></thead>
      <tbody>
        {% for row in section.web_filter.top_categories.rows %}
        <tr><td>{{ row.label }}</td><td>{{ row.count }}</td>
            <td><span class="threat threat-{{ row.level }}">{{ ctx.t['threat_' ~ row.level] }}</span></td></tr>
        {% endfor %}
      </tbody>
    </table>
    {% for tbl in [section.web_filter.top_sites, section.web_filter.top_initiators] %}
    <table class="ranked">
      <caption>{{ tbl.title }}</caption>
      <thead><tr><th>{{ tbl.columns[0] }}</th><th>{{ tbl.columns[1] }}</th></tr></thead>
      <tbody>
        {% for value, count in tbl.rows %}<tr><td>{{ value }}</td><td>{{ count }}</td></tr>{% endfor %}
      </tbody>
    </table>
    {% endfor %}
    {% endif %}

  </section>
  {% endfor %}
</body>
</html>
