# OPNGMS production environment — copy to `.env` and replace every change-me value.
# `.env` is gitignored: never commit real secrets.

# --- Container image version (GHCR) ---
# Pins the ghcr.io/l0rdg3x/opngms-{backend,frontend} tag the compose files pull. Default `latest` =
# the newest tagged release (images are published only from semver tags). Pin a specific release for
# reproducible deploys, e.g. OPNGMS_VERSION=0.1.0
OPNGMS_VERSION=latest

# --- Postgres (the owner/superuser the DB container creates on first boot) ---
POSTGRES_USER=opngms
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=opngms

# --- Application database URLs ---
# The API connects as the NON-superuser `opngms_app` role so Postgres RLS is enforced (the core
# multi-tenant isolation). That role + its password are created by migration 0003 from APP_ROLE_PASSWORD
# (below). Set a strong value there and make DATABASE_URL's password match it.
DATABASE_URL=postgresql+asyncpg://opngms_app:change-me-strong-app-password@db:5432/opngms

# App-role DB password used by the `migrate` job to CREATE/ALTER the `opngms_app` role.
# MUST equal the password embedded in DATABASE_URL above. Interpolated into SQL DDL — no single
# quotes. The `migrate` service inherits this via env_file: .env (see docker-compose.prod.yml).
# The app REFUSES TO START while this (or any secret below) still says "change-me".
APP_ROLE_PASSWORD=change-me-strong-app-password

# The worker + migrations connect as the owner (DDL + fleet-wide writes; bypasses RLS — trusted
# backend only). The password MUST match POSTGRES_PASSWORD above.
ADMIN_DATABASE_URL=postgresql+asyncpg://opngms:change-me-strong-db-password@db:5432/opngms

# --- Redis broker ---
REDIS_URL=redis://redis:6379

# --- Timezone ---
# Container/system timezone (an IANA name, e.g. Europe/Rome, America/New_York). Applied to db, api,
# worker and frontend so logs read in your local time. Data is always stored in UTC (timestamptz),
# and scheduled-report HOURS are interpreted in UTC by design — changing TZ does NOT shift when a
# report is sent, only how timestamps appear in container logs. Leave UTC unless you want local-time logs.
TZ=UTC

# --- Secrets — generate fresh values, do not reuse these placeholders ---
# Session signing secret:   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-random-session-secret
# Fernet key for device-secret encryption:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=change-me-fernet-key
# Comma-separated retired Fernet keys kept for decryption only during rotation; empty when not rotating.
MASTER_KEY_OLD_KEYS=

# --- Report email delivery ---
# SMTP for scheduled report delivery is configured IN-APP by the superadmin
# (Admin -> SMTP delivery), NOT here. The password is encrypted at rest with MASTER_KEY.
# OAuth2 SMTP (Gmail / Microsoft 365): the refresh token can be pasted in-app, OR — EXPERIMENTAL,
# UNTESTED against a live provider — obtained via the in-app "Connect" button. The Connect flow needs
# PUBLIC_BASE_URL set (https only) so it can build the OAuth redirect URI
# `${PUBLIC_BASE_URL}/api/admin/smtp/oauth/{provider}/callback`, which must be registered in your OAuth
# app. Leave empty to keep the feature off (manual refresh-token entry still works).
PUBLIC_BASE_URL=

# --- Frontend exposure & TLS (see the README "Deployment" guide; pick ONE model) ---
# 1) BEHIND YOUR REVERSE PROXY / LB (default, base compose only): the frontend serves plain HTTP bound
#    to localhost. Point your upstream TLS-terminating proxy at FRONTEND_BIND:FRONTEND_HTTP_PORT and
#    have it forward `X-Forwarded-Proto: https`.
FRONTEND_BIND=127.0.0.1            # set 0.0.0.0 ONLY if something else terminates TLS in front
FRONTEND_HTTP_PORT=8080            # host port the base frontend listens on (localhost)
SERVER_NAME=opngms.example.com     # your domain (used by built-in TLS; informational otherwise)

# 2) BUILT-IN TLS with YOUR cert (docker-compose.tls.yml): put fullchain.pem + privkey.pem here.
CERT_DIR=./certs

# Published 80/443 host ports for the built-in-TLS / Caddy / Traefik overrides.
HTTP_PORT=80
HTTPS_PORT=443

# 3) AUTOMATIC TLS (Let's Encrypt) via Caddy OR Traefik (docker-compose.caddy.yml | .traefik.yml):
#    requires a public DNS name pointing at this host + reachable ports 80/443.
DOMAIN=opngms.example.com
ACME_EMAIL=you@example.com

# --- Log lake (optional, Phase 1; only used with docker-compose.logs.yml) ---
# Devices ship logs over mTLS syslog to this receiver (public name/IP + port reachable BY the devices).
SYSLOG_RECEIVER_HOST=logs.opngms.example
SYSLOG_TLS_PORT=6514
# OpenSearch is internal-only (plain HTTP, security disabled, not published); the backend/receiver reach it here.
# Leave EMPTY (OPENSEARCH_URL=) in a core-only deployment without the log lake — the daily per-tenant
# log-retention purge then no-ops instead of trying (and failing) to reach OpenSearch.
OPENSEARCH_URL=http://opensearch:9200
# Default log-lake retention (days). Now the GLOBAL default, per-tenant-overridable from the UI; the worker
# (purge_log_lake) owns deletion. Surfaced in the runtime registry as log_lake_retention_days.
LOG_RETENTION_DAYS=30

# =====================================================================================================
# Boot-time tuning (requires restart)
# These are read once at process start; change a value here and restart the api/worker to apply it.
# Every key below is OPTIONAL — the shipped default reproduces the previous hardcoded behavior.
# =====================================================================================================
# ARQ worker concurrency: how many jobs the worker runs at once. Operations on DIFFERENT boxes already
# run concurrently up to this cap; a single box still serializes via a per-device lock. Raise it to
# drain a larger fleet faster, lower it to keep a small host calm. (>=1)
WORKER_MAX_JOBS=10
# SQLAlchemy connection pool, applied to BOTH the API (opngms_app/RLS) and worker (owner) engines.
# DB_POOL_SIZE = steady connections kept open; DB_MAX_OVERFLOW = extra burst connections beyond it.
# Size them with your Postgres max_connections and the number of api/worker replicas in mind.
DB_POOL_SIZE=5          # (>=1)
DB_MAX_OVERFLOW=10      # (>=0)
# Default per-request timeout (seconds) for outbound calls to managed OPNsense boxes. Raise it for
# high-latency links to remote firewalls; some slow reconfigure calls use their own longer timeout. (>0)
OPNSENSE_HTTP_TIMEOUT=10.0
#
# Also boot-time (already supported above / elsewhere): the worker cron cadences
# (INGEST_EVERY_MINUTES, CONFIG_BACKUP_HOUR, SWEEP_EVERY_MINUTES, CERT_RENEWAL_HOUR,
# SESSION_CLEANUP_MINUTE, SILENT_ALERT_CRON_MINUTE), REDIS_URL, the DB URLs, the catalog/geoip release
# base URLs, SYSLOG_RECEIVER_HOST/PORT and OPENSEARCH_URL — all read at startup.

# =====================================================================================================
# Runtime defaults (initial value; then editable live from the superadmin System page)
# These set the STARTING/FALLBACK value only. Once running, a superadmin changes them from System ->
# Runtime settings without a restart, and a tenant sets per-tenant retention on its Retention card.
#
# PERSISTENCE — important: those in-app overrides are stored in Postgres (`app_setting.runtime_config`
# for the global values; `tenant_retention` for the per-tenant ones), which lives in the `opngms_pg`
# named volume. They therefore SURVIVE a restart / image upgrade / `docker compose down` + `up`:
# restarting the stack does NOT reset settings to these defaults. The value here is read only as the
# fallback for a setting that has NO override yet — and changing it here AFTER you've overridden a
# setting in the UI has no effect (the DB override wins; change it in the UI instead).
# The ONLY thing that wipes the overrides is destroying the volume (`docker compose down -v`), which
# also deletes all your data.
# (More runtime knobs — e.g. the firmware-poll cadence — appear on that page; not all need an env var here.)
# =====================================================================================================
# Brute-force protection on the login endpoint: lock a (email|ip) key after MAX_ATTEMPTS failures
# within the sliding LOCKOUT_WINDOW seconds.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_SECONDS=900
# Session lifetime: absolute cap (TTL_HOURS) and sliding idle timeout (IDLE_MINUTES).
SESSION_TTL_HOURS=12
SESSION_IDLE_MINUTES=120
# Silent-tenant detector: master switch + how long a tenant may ship no logs before it is flagged.
SILENT_ALERT_ENABLED=true
SILENT_ALERT_AFTER_HOURS=6
# Distribution auto-fetch: on a cache-miss, fetch+cache the versioned catalog / GeoIP mmdb from the
# release assets (set false for an air-gapped, cache-only deploy).
CATALOG_AUTO_FETCH=true
GEOIP_AUTO_FETCH=true
# Data retention (days) — the GLOBAL DEFAULT for each store behind the dashboards/reports; each tenant
# can OVERRIDE its own from the Retention card (effective = per-tenant override, else this default). The
# log lake's global default is LOG_RETENTION_DAYS above. A report can't be scheduled to span more days
# than the effective retention of the data its sections use.
PERIMETER_RETENTION_DAYS=30
EVENTS_RETENTION_DAYS=90
METRICS_RETENTION_DAYS=30
