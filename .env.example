# OPNGMS production environment — copy to `.env` and replace every change-me value.
# `.env` is gitignored: never commit real secrets.

# --- Postgres (the owner/superuser the DB container creates on first boot) ---
POSTGRES_USER=opngms
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=opngms

# --- Application database URLs ---
# The API connects as the NON-superuser `opngms_app` role so Postgres RLS is enforced (the core
# multi-tenant isolation). That role + its password are created by migration 0003 from APP_ROLE_PASSWORD
# (below). Set a strong value there and make DATABASE_URL's password match it.
DATABASE_URL=postgresql+asyncpg://opngms_app:change-me-strong-app-password@db:5432/opngms

# App-role DB password used by the `migrate` job to CREATE/ALTER the `opngms_app` role.
# MUST equal the password embedded in DATABASE_URL above. Interpolated into SQL DDL — no single
# quotes. The `migrate` service inherits this via env_file: .env (see docker-compose.prod.yml).
# The app REFUSES TO START while this (or any secret below) still says "change-me".
APP_ROLE_PASSWORD=change-me-strong-app-password

# The worker + migrations connect as the owner (DDL + fleet-wide writes; bypasses RLS — trusted
# backend only). The password MUST match POSTGRES_PASSWORD above.
ADMIN_DATABASE_URL=postgresql+asyncpg://opngms:change-me-strong-db-password@db:5432/opngms

# --- Redis broker ---
REDIS_URL=redis://redis:6379

# --- Timezone ---
# Container/system timezone (an IANA name, e.g. Europe/Rome, America/New_York). Applied to db, api,
# worker and frontend so logs read in your local time. Data is always stored in UTC (timestamptz),
# and scheduled-report HOURS are interpreted in UTC by design — changing TZ does NOT shift when a
# report is sent, only how timestamps appear in container logs. Leave UTC unless you want local-time logs.
TZ=UTC

# --- Secrets — generate fresh values, do not reuse these placeholders ---
# Session signing secret:   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-random-session-secret
# Fernet key for device-secret encryption:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=change-me-fernet-key
# Comma-separated retired Fernet keys kept for decryption only during rotation; empty when not rotating.
MASTER_KEY_OLD_KEYS=

# --- Report email delivery ---
# SMTP for scheduled report delivery is configured IN-APP by the superadmin
# (Admin -> SMTP delivery), NOT here. The password is encrypted at rest with MASTER_KEY.

# --- Frontend exposure & TLS (see the README "Deployment" guide; pick ONE model) ---
# 1) BEHIND YOUR REVERSE PROXY / LB (default, base compose only): the frontend serves plain HTTP bound
#    to localhost. Point your upstream TLS-terminating proxy at FRONTEND_BIND:FRONTEND_HTTP_PORT and
#    have it forward `X-Forwarded-Proto: https`.
FRONTEND_BIND=127.0.0.1            # set 0.0.0.0 ONLY if something else terminates TLS in front
FRONTEND_HTTP_PORT=8080            # host port the base frontend listens on (localhost)
SERVER_NAME=opngms.example.com     # your domain (used by built-in TLS; informational otherwise)

# 2) BUILT-IN TLS with YOUR cert (docker-compose.tls.yml): put fullchain.pem + privkey.pem here.
CERT_DIR=./certs

# Published 80/443 host ports for the built-in-TLS / Caddy / Traefik overrides.
HTTP_PORT=80
HTTPS_PORT=443

# 3) AUTOMATIC TLS (Let's Encrypt) via Caddy OR Traefik (docker-compose.caddy.yml | .traefik.yml):
#    requires a public DNS name pointing at this host + reachable ports 80/443.
DOMAIN=opngms.example.com
ACME_EMAIL=you@example.com
